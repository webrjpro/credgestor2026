# CredGestor
# Modo offline.
#
# O desktop nao precisa de .env. O backend embarcado recebe DB_PATH, PORT e
# JWT_SECRET gerado pelo processo principal em runtime.
#
# Use variaveis de ambiente apenas para testes tecnicos do backend isolado.
# Gere um segredo forte com:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# JWT_SECRET=cole_o_valor_gerado_aqui
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
