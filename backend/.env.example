PORT=4000

# ─── JWT ────────────────────────────────────────────────────────────────────
# MODO EMBARCADO (Electron): JWT_SECRET é GERADO e INJETADO automaticamente
# MODO STANDALONE: gere um secret com:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
# JWT_SECRET=cole_o_valor_gerado_aqui
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# ─── BANCO DE DADOS ──────────────────────────────────────────────────────────
DB_PATH=./data/credgestor-api.db

# ─── CORS ────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:4000,http://127.0.0.1:4000

# ─── AMBIENTE ────────────────────────────────────────────────────────────────
NODE_ENV=production

# ─── RATE LIMIT ──────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=2000
LOGIN_RATE_LIMIT_MAX=20
