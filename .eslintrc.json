{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "ignorePatterns": [
    "node_modules/",
    "dist/",
    "dist-renderer/",
    ".git/",
    ".tools/"
  ],
  "rules": {
    "no-unused-vars": "off",
    "no-undef": "off",
    "eqeqeq": "off",
    "no-console": "off",
    "prefer-const": "off",
    "no-var": "off",
    "no-unreachable": "warn",
    "no-empty": "warn"
  },
  "globals": {
    "supabase": "readonly",
    "Swal": "readonly",
    "Chart": "readonly",
    "XLSX": "readonly"
  }
}
